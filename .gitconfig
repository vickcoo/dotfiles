[alias]
    # show diff in vim
	diffvim = "!f() { git diff \"$@\" | nvim -R -c \"syntax on\" -c \"setlocal ft=diff\" -; }; f"

    # l: show log
    # --all: show all branches
    # --pretty=format:'...': format output
    #   %h: abbreviated commit hash
    #   %d: ref names (tags, branches)
    #   %s: commit message
    #   %an: author name
    #   %ar: relative time (e.g., 2 days ago)
    l = log --all --pretty=format:'%C(auto)%h%d %C(reset)%s %C(dim white)(%an, %ar)%C(reset)'

    # lg: show log with graph
    # --graph: show ASCII graph of branch structure
    # --all: show all branches
    # --pretty=format:'...': format output
    #   %h: abbreviated commit hash
    #   %d: ref names (tags, branches)
    #   %s: commit message
    #   %an: author name
    #   %ar: relative time (e.g., 2 days ago)
    lg = log --graph --all --pretty=format:'%C(auto)%h%d %C(reset)%s %C(dim white)(%an, %ar)%C(reset)'

